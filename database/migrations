const db = require("./db");

const createTable = () => {
  const query = `
    CREATE TABLE IF NOT EXISTS medicamentos (
      id INT AUTO_INCREMENT PRIMARY KEY,
      nombre VARCHAR(255),
      precio INT
    )
  `;

  db.query(query, (err) => {
    if (err) {
      console.error(err);
    } else {
      console.log("Table ready");
    }
  });
};

module.exports = createTable;
