const Medicamento = require("../models/medicamento.model");

// Get all medicines
exports.getMedicamentos = async (req, res) => {
  try {
    const data = await Medicamento.getAll();
    res.json(data);
  } catch (error) {
    res.status(500).json({ error: "Error fetching medicines" });
  }
};

// Create medicine
exports.createMedicamento = async (req, res) => {
  try {
    const newMedicamento = await Medicamento.create(req.body);
    res.json(newMedicamento);
  } catch (error) {
    res.status(500).json({ error: "Error creating medicine" });
  }
};
