let medicamentos = [
  { id: 1, nombre: "Paracetamol", precio: 5 },
  { id: 2, nombre: "Ibuprofen", precio: 8 }
];

// Get all
exports.getAll = async () => {
  return medicamentos;
};

// Create new
exports.create = async (data) => {
  const newMedicamento = {
    id: medicamentos.length + 1,
    nombre: data.nombre,
    precio: data.precio
  };

  medicamentos.push(newMedicamento);
  return newMedicamento;
};
